page {
  min-height: 100%;
  background: #F5F3F0;
  color: #3D3D3D;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Helvetica Neue", Arial, sans-serif;
}

button,
input,
textarea,
picker {
  max-width: 100%;
  box-sizing: border-box;
  font-family: inherit;
}

button {
  margin-left: 0;
  margin-right: 0;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 72rpx 40rpx 48rpx;
}

.screen-page {
  display: flex;
  flex-direction: column;
}

.app-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 88rpx;
  margin-bottom: 36rpx;
}

.header-main {
  min-width: 0;
  flex: 1;
}

.header-title {
  color: #8B9A8F;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header-subtitle {
  color: #888888;
  font-size: 24rpx;
  line-height: 1.45;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header-icons {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  gap: 16rpx;
}

.icon-btn,
.back-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 72rpx !important;
  height: 72rpx;
  min-width: 72rpx !important;
  max-width: 72rpx !important;
  min-height: 72rpx;
  margin: 0 !important;
  padding: 0 !important;
  border-radius: 50% !important;
  background: #FFFFFF;
  color: #3D3D3D;
  font-size: 32rpx;
  line-height: 1 !important;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(61, 61, 61, 0.06);
  transition: transform 0.18s ease, opacity 0.18s ease, background-color 0.18s ease, box-shadow 0.18s ease;
}

.card {
  box-sizing: border-box;
  background: #FFFFFF;
  border: 1rpx solid #E8E3D8;
  border-radius: 20rpx;
  box-shadow: 0 16rpx 42rpx rgba(61, 61, 61, 0.06);
}

.btn-primary,
.btn-secondary,
.btn-option {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100% !important;
  max-width: 100%;
  min-width: 0;
  min-height: 88rpx;
  margin-left: 0 !important;
  margin-right: 0 !important;
  padding: 0 28rpx !important;
  border-radius: 20rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
  text-align: center;
  transition: transform 0.18s ease, opacity 0.18s ease, background-color 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
}

.btn-primary {
  background: #8B9A8F;
  color: #FFFFFF;
}

.btn-secondary {
  background: #FFFFFF;
  color: #8B9A8F;
  border: 1rpx solid #E8E3D8;
}

.btn-primary:active,
.btn-secondary:active,
.btn-option:active,
.icon-btn:active,
.back-btn:active,
.quick-q-btn:active,
.quick-qa-btn:active,
.send-btn:active,
.control-hover {
  opacity: 0.86;
  transform: scale(0.98);
}

.btn-primary:active,
.quick-qa-btn:active,
.send-btn:active {
  background: #7E8F84;
}

.btn-secondary:active,
.btn-option:active,
.icon-btn:active,
.back-btn:active {
  background: #F5F3F0;
}

.btn-option {
  background: #FFFFFF;
  color: #3D3D3D;
  border: 1rpx solid #E8E3D8;
  line-height: 1.35;
  padding-top: 24rpx;
  padding-bottom: 24rpx;
}

.btn-option.selected {
  background: #F5F3F0;
  border-color: #8B9A8F;
  color: #8B9A8F;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  color: #3D3D3D;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.form-input,
.form-select,
.form-textarea {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  min-height: 88rpx;
  box-sizing: border-box;
  padding: 0 28rpx;
  border: 1rpx solid #E8E3D8;
  border-radius: 20rpx;
  background: #FFFFFF;
  color: #3D3D3D;
  font-size: 28rpx;
}

.form-textarea {
  height: 180rpx;
  padding-top: 22rpx;
  line-height: 1.5;
}

.section-title {
  color: #3D3D3D;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.3;
}

.muted {
  color: #888888;
}

.privacy-notice {
  color: #888888;
  font-size: 22rpx;
  line-height: 1.5;
  text-align: center;
  margin-top: 28rpx;
}

.loading-dots {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #8B9A8F;
  animation: dotPulse 1s infinite ease-in-out;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.15s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes dotPulse {
  0%, 80%, 100% {
    opacity: 0.35;
    transform: translateY(0);
  }
  40% {
    opacity: 1;
    transform: translateY(-6rpx);
  }
}
