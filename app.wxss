page {
  min-height: 100%;
  background: #f5f3f0;
  color: #4a4a4a;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(184, 197, 187, 0.3), transparent 32%),
    linear-gradient(180deg, #f7f3ed 0%, #f5f3f0 100%);
}

.page-with-tabbar {
  padding-bottom: 160rpx;
}

.card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(125, 157, 156, 0.12);
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #4a4a4a;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #8c8c8c;
  line-height: 1.7;
}

.section-title {
  margin: 24rpx 0 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #4a4a4a;
}

.button-primary,
.button-accent,
.button-outline {
  width: 100%;
  min-height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.button-primary {
  background: #7d9d9c;
  color: #ffffff;
}

.button-accent {
  background: #d4a59a;
  color: #ffffff;
}

.button-outline {
  background: #ffffff;
  color: #4a4a4a;
  border: 2rpx solid #b8c5bb;
}

.label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #4a4a4a;
}

.field {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 2rpx solid #e6e6e6;
  box-sizing: border-box;
}

.muted {
  color: #8c8c8c;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(125, 157, 156, 0.12);
  color: #7d9d9c;
  font-size: 22rpx;
}

.score {
  font-size: 72rpx;
  line-height: 1;
  font-weight: 700;
  color: #d4a59a;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.grid-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0efec;
  font-size: 28rpx;
}

.list-item:last-child {
  border-bottom: none;
}

.overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 99;
}

.sheet {
  width: 100%;
  max-height: 84vh;
  background: #ffffff;
  border-radius: 36rpx 36rpx 0 0;
  padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.sheet-close {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f5f3f0;
  color: #8c8c8c;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}
