.api-page {
  padding-bottom: 60rpx;
}

.profile-card,
.loading-card,
.result-card,
.error-card {
  margin-top: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #f0efec;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: #8c8c8c;
}

.info-value {
  color: #4a4a4a;
  text-align: right;
}

.loading-card {
  min-height: 420rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.spinner {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #7d9d9c;
  animation: bounce 1.1s infinite ease-in-out;
}

.dot-2 {
  animation-delay: 0.15s;
}

.dot-3 {
  animation-delay: 0.3s;
}

.loading-title {
  margin-top: 32rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #4a4a4a;
}

.loading-subtitle {
  margin-top: 16rpx;
  text-align: center;
  color: #8c8c8c;
  line-height: 1.8;
}

.result-text,
.error-text {
  margin-top: 8rpx;
  white-space: pre-wrap;
  line-height: 1.9;
  color: #4a4a4a;
}

.error-text {
  color: #b25e4d;
}

.retry-button {
  margin-top: 28rpx;
}

@keyframes bounce {
  0%,
  80%,
  100% {
    transform: scale(0.7);
    opacity: 0.45;
  }

  40% {
    transform: scale(1);
    opacity: 1;
  }
}