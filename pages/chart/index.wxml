<view class="page page-with-tabbar chart-page">
  <view class="title">我的命盘</view>
  <view class="subtitle">紫微斗数十二宫详解，结合原型中的主宫位与辅助星曜展示。</view>

  <view class="card chart-card">
    <view class="grid-4 chart-grid">
      <view wx:for="{{palaces}}" wx:key="name" class="palace {{item.main ? 'palace-main' : ''}}">
        <text class="palace-name">{{item.name}}</text>
        <text class="palace-star {{item.main ? 'palace-star-main' : ''}}">{{item.star}}</text>
      </view>
    </view>
  </view>

  <view class="card detail-card">
    <view class="section-title">宫位详解</view>
    <view wx:for="{{details}}" wx:key="palace" class="detail-row">
      <view>
        <view class="detail-title">{{item.palace}}（{{item.star}}）</view>
        <view class="detail-summary">{{item.summary}}</view>
      </view>
      <view class="detail-mark">详</view>
    </view>
  </view>
</view>
