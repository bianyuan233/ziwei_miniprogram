<view class="page home-page screen-page">
  <view class="app-header">
    <view class="header-main">
      <view class="header-title">顺顺尼</view>
      <view class="header-subtitle">你好，{{userDisplayName}}</view>
    </view>
    <view class="header-icons">
      <view class="icon-btn" hover-class="control-hover" bindtap="goToAccount">👤</view>
      <view class="icon-btn" hover-class="control-hover" bindtap="goToPricing">💳</view>
    </view>
  </view>

  <view class="home-greeting">
    <view class="greeting-text">今天想看哪一份命盘？</view>
  </view>

  <view class="profiles-container">
    <view
      wx:for="{{profiles}}"
      wx:key="id"
      class="profile-card card {{selectedProfileId === item.id ? 'selected' : ''}}"
      hover-class="control-hover"
      data-id="{{item.id}}"
      bindtap="selectProfile"
    >
      <view class="profile-header">
        <view class="profile-info">
          <view class="profile-avatar">{{item.avatarText}}</view>
          <view class="profile-details">
            <view class="profile-name">{{item.name}}</view>
            <view class="profile-date">{{item.birthDate}} · {{item.timeLabel}}</view>
          </view>
        </view>
        <view class="profile-status {{item.calibrationStatus === 'success' ? '' : 'pending'}}">
          {{item.calibrationStatus === 'success' ? '✓ 已校准' : '待校准'}}
        </view>
      </view>
      <view wx:if="{{item.calibrationStatus === 'success'}}" class="profile-meta">准确度 {{item.accuracy}}% · 命盘状态良好</view>
    </view>
  </view>

  <view class="quick-qa-card card">
    <view class="quick-qa-title">💬 快速提问</view>
    <view class="quick-qa-input">
      <input class="quick-qa-field" placeholder="问一个问题..." value="{{quickInput}}" bindinput="handleQuickInput" confirm-type="send" bindconfirm="submitQuickQA" />
      <button class="quick-qa-btn" hover-class="control-hover" bindtap="submitQuickQA">发送</button>
    </view>
    <view class="quick-questions">
      <button class="quick-q-btn" hover-class="control-hover" data-question="今年事业运如何？" bindtap="quickAsk">📊 事业运</button>
      <button class="quick-q-btn" hover-class="control-hover" data-question="感情方面有变化吗？" bindtap="quickAsk">❤ 感情运</button>
      <button class="quick-q-btn" hover-class="control-hover" data-question="这个月财运如何？" bindtap="quickAsk">💰 财运</button>
      <button class="quick-q-btn" hover-class="control-hover" data-question="健康方面要注意什么？" bindtap="quickAsk">💪 健康</button>
    </view>
  </view>

  <view wx:if="{{subscriptionStatus.showExpiry}}" class="expiry-card">
    <view class="expiry-title">⏰ 会员即将过期</view>
    <view class="expiry-text">{{subscriptionStatus.text}}</view>
  </view>

  <view class="stats-row">
    <view class="stat-card card">
      <view class="stat-value">{{qaCount}}</view>
      <view class="stat-label">次命理问答</view>
    </view>
    <view class="stat-card card">
      <view class="stat-value">{{profileCount}}</view>
      <view class="stat-label">个命盘档案</view>
    </view>
  </view>

  <view class="action-buttons">
    <view class="action-btn card" hover-class="control-hover" bindtap="addProfile">
      <view class="action-icon">＋</view>
      <view class="action-label">添加家人</view>
    </view>
    <view class="action-btn card" hover-class="control-hover" bindtap="goToQA">
      <view class="action-icon">？</view>
      <view class="action-label">问点什么</view>
    </view>
  </view>

  <button class="btn-primary main-btn" hover-class="control-hover" bindtap="goToQA">💬 开始问答</button>
  <button class="btn-secondary main-btn" hover-class="control-hover" bindtap="viewChart">查看完整命盘</button>

  <view class="privacy-notice">本机不保存对话记录 · 服务端仅用于本次分析处理</view>

  <app-modal
    visible="{{modal.visible}}"
    icon="{{modal.icon}}"
    title="{{modal.title}}"
    message="{{modal.message}}"
    buttons="{{modal.buttons}}"
    bindaction="onModalAction"
  />
</view>
