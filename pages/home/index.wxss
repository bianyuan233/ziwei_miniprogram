.home-greeting {
  margin: -14rpx 0 24rpx;
}

.greeting-text {
  color: #888888;
  font-size: 26rpx;
}

.profiles-container {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.profile-card {
  padding: 28rpx;
  transition: border-color 0.2s ease;
}

.profile-card.selected {
  border-color: #8B9A8F;
}

.profile-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.profile-info {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 22rpx;
}

.profile-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #8B9A8F;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 72rpx;
  text-align: center;
}

.profile-details {
  min-width: 0;
}

.profile-name {
  color: #3D3D3D;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.profile-date {
  color: #888888;
  font-size: 23rpx;
  line-height: 1.4;
  margin-top: 4rpx;
}

.profile-status {
  min-width: 116rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(123, 155, 168, 0.14);
  color: #7B9BA8;
  font-size: 22rpx;
  text-align: center;
}

.profile-status.pending {
  background: rgba(232, 184, 104, 0.18);
  color: #C4882F;
}

.profile-meta {
  color: #8B9A8F;
  font-size: 24rpx;
  margin-top: 20rpx;
}

.quick-qa-card {
  padding: 28rpx;
  margin-top: 28rpx;
}

.quick-qa-title {
  color: #3D3D3D;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.quick-qa-input {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.quick-qa-field {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #F5F3F0;
  color: #3D3D3D;
  font-size: 26rpx;
}

.quick-qa-btn {
  width: 112rpx;
  min-width: 112rpx;
  height: 76rpx;
  padding: 0;
  border-radius: 18rpx;
  background: #8B9A8F;
  color: #FFFFFF;
  font-size: 26rpx;
  line-height: 76rpx;
}

.quick-questions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.quick-q-btn {
  min-width: 0;
  max-width: 100%;
  height: 68rpx;
  padding: 0 12rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  border: 1rpx solid #E8E3D8;
  color: #3D3D3D;
  font-size: 24rpx;
  line-height: 68rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.expiry-card {
  margin-top: 24rpx;
  padding: 22rpx 26rpx;
  border-radius: 20rpx;
  background: rgba(232, 184, 104, 0.16);
}

.expiry-title {
  color: #9C6B22;
  font-size: 28rpx;
  font-weight: 700;
}

.expiry-text {
  color: #9C6B22;
  font-size: 24rpx;
  margin-top: 6rpx;
}

.stats-row,
.action-buttons {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 22rpx;
  margin-top: 24rpx;
}

.stat-card {
  padding: 24rpx;
  text-align: center;
}

.stat-value {
  color: #C4A370;
  font-size: 42rpx;
  font-weight: 700;
}

.stat-label {
  color: #888888;
  font-size: 22rpx;
  margin-top: 6rpx;
}

.action-btn {
  padding: 26rpx 20rpx;
  text-align: center;
}

.action-icon {
  color: #8B9A8F;
  font-size: 42rpx;
  font-weight: 700;
}

.action-label {
  color: #3D3D3D;
  font-size: 24rpx;
  margin-top: 6rpx;
}

.main-btn {
  margin-top: 24rpx;
}
