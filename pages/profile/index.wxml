<view class="page page-with-tabbar profile-page">
  <view class="profile-top card">
    <view class="profile-avatar">{{profile.avatarText}}</view>
    <view class="profile-name">{{profile.nickname}}</view>
    <view class="muted">ID: {{profile.userId}}</view>
  </view>

  <view class="member-card">
    <view>
      <view class="member-title">{{profile.memberType}}</view>
      <view class="member-expire">有效期至 {{profile.memberExpireAt}}</view>
    </view>
    <button class="member-button" bindtap="handleUpgrade">{{isPaid ? '续费' : '升级'}}</button>
  </view>

  <view class="card settings-card">
    <view class="list-item" bindtap="handlePolicy">
      <text>隐私政策</text>
      <text class="muted">查看</text>
    </view>
    <view class="list-item" bindtap="handleContact">
      <text>联系我们</text>
      <text class="muted">咨询</text>
    </view>
    <view class="list-item danger-item" bindtap="handleReset">
      <text>清除所有数据（重置新手）</text>
      <text class="muted">重置</text>
    </view>
  </view>

  <view class="profile-footer muted">顺顺念 V1.0 · 命理解读仅作趋势参考，人生选择权始终在你手中。</view>
</view>
