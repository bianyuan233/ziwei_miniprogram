<view class="page register-page screen-page">
  <view class="step-indicator">
    <view class="step-dot {{step >= 1 ? 'active' : ''}}"></view>
    <view class="step-dot {{step >= 2 ? 'active' : ''}}"></view>
  </view>

  <block wx:if="{{step === 1}}">
    <view class="welcome-illustration">
      <view class="welcome-icon">✨</view>
      <view class="welcome-text">欢迎来到命运指引</view>
      <view class="welcome-desc">让我们先了解你的基本信息</view>
    </view>

    <view class="form-group">
      <text class="form-label">手机号码</text>
      <input class="form-input" type="number" placeholder="请输入手机号码" value="{{phone}}" bindinput="handlePhoneInput" maxlength="20" />
    </view>

    <view class="form-group">
      <text class="form-label">性别</text>
      <picker mode="selector" range="{{genders}}" value="{{genderIndex}}" bindchange="handleGenderChange">
        <view class="form-select">{{selectedGender}}</view>
      </picker>
    </view>

    <button class="btn-primary next-btn" hover-class="control-hover" bindtap="handleNextStep">下一步</button>
  </block>

  <block wx:if="{{step === 2}}">
    <view class="welcome-illustration">
      <view class="welcome-icon">🎂</view>
      <view class="welcome-text">请告诉我你的生日</view>
      <view class="welcome-desc">出生年月日和时辰</view>
    </view>

    <view class="form-group">
      <text class="form-label">出生日期</text>
      <picker mode="date" value="{{birthDate}}" end="{{today}}" bindchange="handleDateChange">
        <view class="form-select {{birthDate ? '' : 'placeholder'}}">{{birthDateText}}</view>
      </picker>
    </view>

    <view class="form-group">
      <text class="form-label">出生时辰</text>
      <picker mode="selector" range="{{timeOptions}}" range-key="label" value="{{timeOptionIndex}}" bindchange="handleTimeChange">
        <view class="form-select">{{selectedTimeLabel}}</view>
      </picker>
    </view>

    <view class="form-group">
      <text class="form-label">档案名称（如：本人、妈妈等）</text>
      <input class="form-input" placeholder="为这个八字起个名字" value="{{profileName}}" bindinput="handleProfileNameInput" maxlength="12" />
    </view>

    <view class="button-row">
      <button class="btn-secondary" hover-class="control-hover" data-step="1" bindtap="goToStep">上一步</button>
      <button class="btn-primary" hover-class="control-hover" bindtap="completeRegistration">完成注册</button>
    </view>
  </block>

  <app-modal
    visible="{{modal.visible}}"
    icon="{{modal.icon}}"
    title="{{modal.title}}"
    message="{{modal.message}}"
    buttons="{{modal.buttons}}"
    bindaction="onModalAction"
  />
</view>
