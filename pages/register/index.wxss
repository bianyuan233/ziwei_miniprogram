.register-page {
  justify-content: flex-start;
}

.step-indicator {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin: 12rpx 0 52rpx;
}

.step-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #E8E3D8;
  transition: all 0.2s ease;
}

.step-dot.active {
  width: 42rpx;
  border-radius: 999rpx;
  background: #8B9A8F;
}

.welcome-illustration {
  padding: 32rpx 0 46rpx;
  text-align: center;
}

.welcome-icon {
  font-size: 86rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}

.welcome-text {
  color: #8B9A8F;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.welcome-desc {
  color: #888888;
  font-size: 26rpx;
  line-height: 1.5;
  margin-top: 10rpx;
}

.form-select {
  display: flex;
  align-items: center;
}

.placeholder {
  color: #B0AAA0;
}

.next-btn {
  margin-top: 28rpx;
}

.button-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 20rpx;
  margin-top: 30rpx;
}

.button-row .btn-primary,
.button-row .btn-secondary {
  padding-left: 16rpx;
  padding-right: 16rpx;
}
