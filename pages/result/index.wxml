<view class="page result-page">
  <view class="title-block">
    <view class="title">命盘已校准</view>
    <view class="subtitle">基于你确认的人生轨迹，系统已锁定更匹配的时辰模型。</view>
  </view>

  <view class="card score-card">
    <view class="tag">匹配完成</view>
    <view class="score score-space">{{score}}%</view>
    <view class="score-hint">共匹配 {{yesCount}} 个关键人生节点</view>

    <view class="grid-4 chart-grid">
      <view wx:for="{{palaces}}" wx:key="name" class="palace {{item.main ? 'palace-main' : ''}}">
        <text class="palace-name">{{item.name}}</text>
        <text class="palace-star">{{item.star}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">规则溯源</view>
    <view class="rule-copy">{{ruleText}}</view>
  </view>

  <button class="button-primary result-button" bindtap="handleComplete">进入首页</button>
  <button class="button-outline result-button ghost-button" bindtap="handleRetry">重新录入</button>
</view>
