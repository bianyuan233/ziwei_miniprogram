.verify-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.progress-track {
  width: 100%;
  height: 12rpx;
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: #d8e1db;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #7d9d9c;
  transition: width 0.25s ease;
}

.verify-card {
  margin-top: 100rpx;
  text-align: center;
}

.question-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  background: rgba(125, 157, 156, 0.16);
  color: #7d9d9c;
  font-size: 48rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.question-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #4a4a4a;
}

.question-desc {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #8c8c8c;
  line-height: 1.8;
}

.actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.answer-button {
  flex: 1;
  min-height: 88rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.answer-primary {
  background: #88b3a8;
  color: #ffffff;
}

.answer-secondary {
  background: #ffffff;
  color: #7f8a88;
  border: 2rpx solid #d9dfdb;
}

.verify-footer {
  margin-top: 28rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8c8c8c;
}
