<view class="page welcome-page">
  <view class="hero">
    <view class="hero-mark">顺顺念</view>
    <view class="hero-subtitle">AI 紫微命理 · 精准验盘</view>
  </view>

  <view class="card intro-card">
    <view class="field-group">
      <text class="label">性别</text>
      <picker mode="selector" range="{{genders}}" value="{{genderIndex}}" bindchange="handleGenderChange">
        <view class="field picker-field">
          {{genders[genderIndex]}}
        </view>
      </picker>
    </view>

    <view class="field-group">
      <text class="label">出生日期</text>
      <picker mode="date" value="{{birthDate}}" end="{{today}}" bindchange="handleDateChange">
        <view class="field picker-field {{birthDate ? '' : 'placeholder'}}">
          {{birthDate || '请选择出生日期'}}
        </view>
      </picker>
    </view>

    <view class="field-group">
      <text class="label">出生时辰（模糊可选）</text>
      <slider
        min="0"
        max="23"
        step="1"
        value="{{birthHour}}"
        activeColor="#7D9D9C"
        backgroundColor="#DCE3DE"
        block-color="#7D9D9C"
        bindchange="handleHourChange"
      />
      <view class="time-display">{{timeLabel}}</view>
      <view class="field-tip">不确定也没关系，稍后可以通过人生事件继续校准。</view>
    </view>

    <view class="field-group">
      <text class="label">职业</text>
      <picker mode="selector" range="{{professions}}" value="{{professionIndex}}" bindchange="handleProfessionChange">
        <view class="field picker-field profession-field">
          {{professions[professionIndex]}}
        </view>
      </picker>
    </view>

    <button class="button-primary start-btn" bindtap="handleStart">开始验盘</button>
  </view>

  <view class="footer-tip">已帮助 12,450 人找到更匹配的命盘模型</view>
</view>